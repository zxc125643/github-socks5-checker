# Copy to scripts/macos_update_socks5.env and edit only for this Mac.

# How many public candidates to check each run.
MAX_CANDIDATES=1200
MAX_RESULTS=80
CONCURRENCY=24
TIMEOUT_MS=25000
MAX_LATENCY_MS=15000

# Extra true-usability check from this Mac. Nodes must pass both targets by default.
LOCAL_CHECK=true
LOCAL_TIMEOUT_MS=10000
LOCAL_MAX_LATENCY_MS=8000
LOCAL_REQUIRED_SUCCESSES=2
LOCAL_TEST_TARGETS=https://www.gstatic.com/generate_204=204,https://www.cloudflare.com/cdn-cgi/trace=200

# 5-point purity scoring, adapted from yxip_git_action.
MIN_PURITY_SCORE=4.2
PUBLISH_ONLY_CLEAN=false
RETAIN_PREVIOUS_ON_EMPTY=false

GIT_USER_NAME=JERRYZFC
GIT_USER_EMAIL=shrl007@163.com
